---
import info from "@/data/info.json";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={info.meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content={info.meta.title} />
    <meta property="og:description" content={info.meta.description} />
    <meta property="og:image" content={info.meta.ogImage} />
    <meta property="og:url" content="/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={info.meta.ogSiteName} />

    <title>{title}</title>
  </head>
  <body class="bg-[--background] sm:px-28 lg:px-20 px-9 relative overflow-x-hidden">
    <div class="contours-top"></div>
    <slot />
    <div class="contours-bottom"></div>
  </body>
</html>

<style is:global>

  @font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-display: swap;
    font-weight: 100 800;
    src: url('/jetbrains.woff2') format('woff2');
  }

  :root {
    --background: #101010;
    --sec: #a476ff;
    --white: #dfdfdf;
    --white-icon: #f3f3f398;
    --white-icon-tr: #f3f3f310;
  }

  * {
    font-family:
      "JetBrains Mono",
      ui-monospace,
      monospace;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: var(--background);
  }

  /* Contours background */
  .contours-top,
  .contours-bottom {
    position: absolute;
    left: 0;
    width: 100%;
    height: 800px;
    background-image: url(/contours.svg);
    filter: invert(1);
    mix-blend-mode: color-dodge;
    background-repeat: no-repeat;
    background-size: cover;
    z-index: -47;
    opacity: 0.7;
    color: #fff;
    pointer-events: none;
  }

  .contours-top {
    top: 0;
    background-position: top center;
  }

  .contours-bottom {
    bottom: 0;
    background-position: bottom center;
    transform: scaleY(-1);
  }

  /* Scrollbar styles */

  ::-webkit-scrollbar {
    width: 15px;
  }

  ::-webkit-scrollbar-track {
    background: var(--container);
    border-radius: 30px;
  }

  ::-webkit-scrollbar-thumb {
    background: var(--background);
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--pink);
  }

  /* Scrollbar styles for Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--line) var(--container);
  }

  /* Card tilt hover effect */
  .tilt-card {
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .tilt-card:hover {
    transform: perspective(800px) rotateX(1deg) rotateY(-1deg) translateY(-4px);
    box-shadow: 4px 8px 24px rgba(0, 0, 0, 0.25);
  }
</style>
